{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ESNext",
    "outDir": "./out",
    "rootDir": "./src",
    "lib": ["ESNext"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "out"]
}
