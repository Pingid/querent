{
  "name": "querent-vscode",
  "displayName": "Querent SQL",
  "description": "SQL language support with Querent LSP",
  "version": "0.1.0",
  "publisher": "querent",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:sql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sql",
        "aliases": [
          "SQL",
          "sql"
        ],
        "extensions": [
          ".sql"
        ]
      }
    ],
    "commands": [
      {
        "command": "querent.addConnection",
        "title": "Querent: Add Connection"
      },
      {
        "command": "querent.viewConnections",
        "title": "Querent: View Connections"
      },
      {
        "command": "querent.editConnection",
        "title": "Querent: Edit Connection"
      },
      {
        "command": "querent.deleteConnection",
        "title": "Querent: Delete Connection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "reconnecting-websocket": "^4.4.0",
    "vscode-languageclient": "^9.0.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.7.1",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "all",
    "shiftRelativeImports": true
  }
}
